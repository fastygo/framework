package views

import "github.com/fastygo/blocks/marketing"

templ CabPage(email string) {
	@marketing.Hero(marketing.HeroProps{
		Title:    "Welcome, " + email,
		Subtitle: "You are authenticated via SSO.",
		PrimaryAction: marketing.Action{
			Label: "Sign out",
			Href:  "/auth/logout",
		},
	})
}
