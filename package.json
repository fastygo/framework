{
  "name": "fastygo-framework-workspace",
  "private": true,
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "examples/*"
  ],
  "scripts": {
    "vendor:assets:landing": "cd examples/landing && bun run vendor:assets",
    "vendor:assets:web": "cd examples/web && bun run vendor:assets",
    "vendor:assets:blog": "cd examples/blog && bun run vendor:assets",
    "vendor:assets:dashboard": "cd examples/dashboard && bun run vendor:assets",
    "vendor:assets:docs": "cd examples/docs && bun run vendor:assets",
    "vendor:assets:all": "bun run vendor:assets:landing && bun run vendor:assets:web && bun run vendor:assets:blog && bun run vendor:assets:dashboard && bun run vendor:assets:docs",
    "build:css:landing": "tailwindcss -i ./examples/landing/web/static/css/input.css -o ./examples/landing/web/static/css/app.css --minify",
    "build:css:web": "tailwindcss -i ./examples/web/web/static/css/input.css -o ./examples/web/web/static/css/app.css --minify",
    "build:css:blog": "tailwindcss -i ./examples/blog/web/static/css/input.css -o ./examples/blog/web/static/css/app.css --minify",
    "build:css:dashboard": "tailwindcss -i ./examples/dashboard/web/static/css/input.css -o ./examples/dashboard/web/static/css/app.css --minify",
    "build:css:docs": "tailwindcss -i ./examples/docs/web/static/css/input.css -o ./examples/docs/web/static/css/app.css --minify",
    "build:css:all": "bun run build:css:landing && bun run build:css:web && bun run build:css:blog && bun run build:css:dashboard && bun run build:css:docs",
    "build:all": "bun run vendor:assets:all && bun run build:css:all"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@ui8kit/aria": "0.1.0",
    "tailwindcss": "^4.2.1"
  }
}
