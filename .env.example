# Copy to .env: cp .env.example .env
# Generate secrets: openssl rand -base64 32

# OIDC Identity Provider (your @SSO IdP public URL — replace example.com with your domain)
OIDC_ISSUER=https://idp.example.com
OIDC_CLIENT_ID=myapp
OIDC_CLIENT_SECRET=change-me-must-match-sso-env
OIDC_REDIRECT_URI=https://app.example.com/auth/callback

# HMAC key for site session cookies (must stay secret)
SESSION_KEY=change-me-to-a-long-random-secret
